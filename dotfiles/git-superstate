#!/usr/bin/env bash
# --- git-superstate: holistic Git workspace and remote overview ---

# === COLORS ===
RESET="\033[0m"; BOLD="\033[1m"
BLUE="\033[1;34m"; GREEN="\033[1;32m"
YELLOW="\033[1;33m"; MAGENTA="\033[1;35m"
CYAN="\033[1;36m"

# === COLORIZED OUTPUT ===
format() { local c=$1; shift; local txt="$*"; printf "%b%s%b\n" "${!c}" "$txt" "$RESET"; }

# === ARGUMENT PARSING ===
VERBOSE=false
SHOW_LOCAL=true
SHOW_REMOTE=true
SHOW_BETWEEN=true
SHOW_STAGED=true
SHOW_UNSTAGED=true
SHOW_UNTRACKED=true
SHOW_IGNORED=true

while [[ $# -gt 0 ]]; do
    case $1 in
        -v|--verbose) VERBOSE=true ;;
        --no-local) SHOW_LOCAL=false ;;
        --no-remote) SHOW_REMOTE=false ;;
        --no-between-commits) SHOW_BETWEEN=false ;;
        --no-staged) SHOW_STAGED=false ;;
        --no-unstaged) SHOW_UNSTAGED=false ;;
        --no-untracked) SHOW_UNTRACKED=false ;;
        --no-ignored) SHOW_IGNORED=false ;;
        -h|--help)
            echo "==========================================================="
            echo "====================Superstate Usage======================="
            echo "==========================================================="
            echo "Usage: git superstate [options]"
            echo "  -v, --verbose             Print commands before execution"
            echo "  --no-local                Hides diffs between working tree and HEAD"
            echo "  --no-remote               Hides diffs between working tree and remote branch"
            echo "  --no-between-commits      Hides diffs between local commit and remote branch"
            echo "  --no-staged               Hides staged files"
            echo "  --no-unstaged             Hides modified/deleted but unstaged files"
            echo "  --no-untracked            Hides untracked files"
            echo "  --no-ignored              Hides ignored files"
            echo "==========================================================="
            echo "====================Terminology============================"
            echo "==========================================================="
            echo "  Working Tree:   Literally the files you are working on after you Ctrl+S"
            echo "  HEAD:           The 'most up-to-date' revision. This is the last 'git commit' you did."
            echo "  Staged:         All files that you've 'git add'-ed. They are 'staged for commit'"
            echo "  Remote Branch:  The branch on GitHub that the local branch pulls from."
            echo "  Untracked:      Files that have been created, but have never been git added. (Random data files are most common)"
            echo "  Ignored:        Files whose names match a pattern you specify in the .gitignore file at the project root."
            echo "==========================================================="
            echo "====================Git Commands==========================="
            echo "==========================================================="
            echo ""
            echo "  -- Diff a file vs another branch --"
            echo "  git diff <branch> -- <file>"
            echo "    Shows difference between your working tree file and that file on <branch>"
            echo ""
            echo "  -- Diff a file vs a remote branch --"
            echo "  git diff origin/<branch> -- <file>"
            echo "    Same, but compares against the remote copy of <branch>"
            echo ""
            echo "  -- Squash commits --"
            echo "  git rebase -i HEAD~N"
            echo "    Opens editor for last N commits. Change 'pick' -> 's' (squash) on commits"
            echo "    to fold into the one above. The topmost commit stays as 'pick'."
            echo ""
            echo "  -- Delete untracked files wholesale --"
            echo "  git clean -n          (dry run: shows what would be deleted)"
            echo "  git clean -fd         (deletes untracked files and directories)"
            echo ""
            echo "  -- Unstage changes / revert to last commit --"
            echo "  git restore --staged <file>    Unstage a file (keeps working tree changes)"
            echo "  git restore <file>             Discard working tree changes (reverts to HEAD)"
            echo "  git restore --staged --worktree <file>  Both: fully revert to HEAD"
            echo ""
            echo "  -- Create a PR with gh --"
            echo "  git push -u origin <branch>"
            echo "  gh pr create --title \"Title\" --body \"Description\""
            echo "    Add --draft for a draft PR. Omit --body to open an editor."
            echo ""
            echo "  -- restore vs reset vs clean --"
            echo "  git restore <file>         Undo working tree changes on a tracked file"
            echo "  git restore --staged <f>   Move file from staged back to unstaged"
            echo "  git reset HEAD~1           Undo last commit, keep changes in working tree"
            echo "  git reset --hard HEAD      Nuke ALL staged+unstaged changes (cannot undo)"
            echo "  git clean -fd              Delete UNTRACKED files/dirs (cannot undo)"
            echo "  Rule of thumb: restore = tracked-file surgery, reset = commit surgery,"
            echo "                 clean = wipe untracked files"
            echo ""
            echo "  -- Push to a remote branch --"
            echo "  git remote -v                         Check your configured remotes"
            echo "  git ls-remote --heads origin <branch> Check if branch exists on remote"
            echo "  git push -u origin <branch>           Push and set upstream tracking"
            echo "    After -u is set once, plain 'git push' / 'git pull' work automatically."
            echo "==========================================================="
            exit 0 ;;
        *) echo "Unknown option: $1"; exit 1 ;;
    esac
    shift
done

# === VERBOSE EXECUTION WRAPPER ===
run() {
    if $VERBOSE; then printf "%b[git %s]%b\n" "${BOLD}${GREEN}" "$*" "$RESET"; fi
    git "$@"
}

# === VERIFY WE'RE IN A GIT REPO ===
run rev-parse --is-inside-work-tree &>/dev/null || {
    format YELLOW "Not inside a Git repository."
    exit 1
}

# === BRANCH INFO ===
format BLUE "=== BRANCH INFO ==="
BRANCH=$(git branch --show-current 2>/dev/null)
HEAD_HASH=$(git rev-parse --short HEAD 2>/dev/null)
UPSTREAM=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null)

printf "Branch: %s\n" "${BRANCH:-"(detached HEAD)"}"
printf "HEAD:   %s\n" "${HEAD_HASH:-"(none)"}"
if [[ -n "$UPSTREAM" ]]; then
    printf "Tracking: %s\n" "$UPSTREAM"
else
    printf "No upstream branch configured.\n"
fi
printf "\n"

# === STAGED FILES ===
if $SHOW_STAGED; then
    format GREEN "=== STAGED CHANGES (ready to commit) ==="
    run diff --cached --name-status || printf "none\n"
    printf "\n"
fi

# === UNSTAGED FILES ===
if $SHOW_UNSTAGED; then
    format YELLOW "=== UNSTAGED CHANGES (modified/deleted) ==="
    run diff --name-status || printf "none\n"
    printf "\n"
fi

# === UNTRACKED FILES ===
if $SHOW_UNTRACKED; then
    format CYAN "=== UNTRACKED FILES (not added yet) ==="
    run ls-files --others --exclude-standard
    printf "\n"
fi

# === IGNORED FILES ===
if $SHOW_IGNORED; then
    format MAGENTA "=== IGNORED FILES (from .gitignore) ==="
    git status --ignored --short | grep '^!!' | sed 's/^!! //' || printf "none\n"
    printf "\n"
fi

# === LOCAL CHANGES (working tree vs HEAD) ===
if $SHOW_LOCAL; then
    format YELLOW "=== LOCAL DIFF (working tree vs HEAD) ==="
    run diff HEAD --name-status || printf "none\n"
    printf "\n"
fi

# === REMOTE DIFF (working tree vs remote branch) ===
if $SHOW_REMOTE; then
    format CYAN "=== REMOTE DIFF (working tree vs remote branch) ==="
    if git rev-parse --abbrev-ref --symbolic-full-name @{u} &>/dev/null; then
        run diff --name-status @{u} || printf "none\n"
    else
        printf "No upstream branch configured.\n"
    fi
    printf "\n"
fi

# === BETWEEN COMMITS (HEAD vs remote branch) ===
if $SHOW_BETWEEN; then
    format MAGENTA "=== BETWEEN COMMITS (HEAD vs remote branch) ==="
    if git rev-parse --abbrev-ref --symbolic-full-name @{u} &>/dev/null; then
        run diff --name-status HEAD...@{u} || printf "none\n"
        printf "\n"
        format BLUE "Ahead/Behind counts:"
        git rev-list --left-right --count HEAD...@{u} | awk '{print "Ahead:", $1, "Behind:", $2}'
    else
        printf "No upstream branch configured.\n"
    fi
    printf "\n"
fi

# === SUMMARY ===
format BLUE "=== SUMMARY ==="
run status -sb
